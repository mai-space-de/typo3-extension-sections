{
  "name": "maispace/mai-sections",
  "type": "typo3-cms-extension",
  "description": "Provides a simple way to create sections for your website.",
  "homepage": "https://www.maispace.de",
  "authors": [
    {
      "name": "Joel Maximilian Mai",
      "email": "joel@maispace.de",
      "role": "Lead Developer"
    }
  ],
  "require": {
    "php": "^8.2",
    "typo3/cms-core": "^13.4",
    "b13/container": "^3.0",
    "friendsoftypo3/visual-editor": "^1.0"
  },
  "autoload": {
    "psr-4": {
      "Maispace\\MaiSections\\": "Classes/"
    }
  },
  "extra": {
    "typo3/cms": {
      "extension-key": "mai_sections"
    },
    "branch-alias": {
      "dev-main": "13.0.x-dev"
    }
  }
}
